{
  "name": "mmc-cert_generator-js",
  "version": "1.0.0",
  "description": "cambridge score tests calculator",
  "homepage": "https://github.com/ElijahPlushkov/MMC-certificate-generator#readme",
  "bugs": {
    "url": "https://github.com/ElijahPlushkov/MMC-certificate-generator/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ElijahPlushkov/MMC-certificate-generator.git"
  },
  "license": "MIT",
  "author": "Elijah Plushkov",
  "type": "commonjs",
  "main": "main.js",
  "scripts": {
    "start": "electron-forge start",
    "test": "echo \"Error: no test specified\" && exit 1",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "make:win": "electron-forge make --platform win32",
    "make:mac": "electron-forge make --platform darwin",
    "make:linux": "electron-forge make --platform linux",
    "publish": "electron-forge publish"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-deb": "^7.11.1",
    "@electron-forge/maker-dmg": "^7.11.1",
    "@electron-forge/maker-rpm": "^7.11.1",
    "@electron-forge/maker-squirrel": "^7.11.1",
    "@electron-forge/maker-wix": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.1",
    "@electron-forge/plugin-fuses": "^7.11.1",
    "@electron/fuses": "^1.8.0",
    "electron": "^42.0.1",
    "vite": "^8.1.3",
    "vite-plugin-singlefile": "^2.3.3"
  },
  "dependencies": {
    "canvg": "^4.0.3",
    "dompurify": "^3.4.11",
    "electron-squirrel-startup": "^1.0.1",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1"
  }
}
